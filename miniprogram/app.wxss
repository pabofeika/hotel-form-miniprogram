 */

/* ===== 设计 Token ===== */
page {
  /* 字体 */
  --font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 30rpx;
  --font-size-xl: 32rpx;
  --font-size-2xl: 36rpx;
  --font-size-3xl: 40rpx;

  /* 颜色 */
  --color-primary: #2563eb;
  --color-primary-dark: #1d4ed8;
  --color-primary-light: #dbeafe;
  --color-primary-gradient: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);

  --color-bg: #f1f5f9;
  --color-bg-card: #ffffff;
  --color-bg-input: #f8fafc;
  --color-bg-hover: #f0f7ff;

  --color-text-primary: #0f172a;
  --color-text-secondary: #475569;
  --color-text-tertiary: #94a3b8;
  --color-text-placeholder: #cbd5e1;

  --color-border: #e2e8f0;
  --color-border-focus: #2563eb;
  --color-border-active: #bfdbfe;

  --color-success: #16a34a;
  --color-success-bg: #f0fdf4;
  --color-warning: #d97706;
  --color-warning-bg: #fffbeb;
  --color-error: #dc2626;
  --color-error-bg: #fef2f2;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 20rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-2xl: 40rpx;

  /* 圆角 */
  --radius-sm: 10rpx;
  --radius-md: 14rpx;
  --radius-lg: 18rpx;
  --radius-xl: 24rpx;
  --radius-full: 50%;

  /* 阴影 */
  --shadow-sm: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-xl: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);

  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* ===== 过渡动画 ===== */
.fade-in {
  animation: fadeIn 0.3s ease;
}
.slide-up {
  animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(30rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }

/* ===== 按钮系统 ===== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  text-align: center;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
}

.btn:active {
  transform: scale(0.96);
}

.btn-primary {
  background: var(--color-primary-gradient);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-primary:active {
  box-shadow: 0 2rpx 6rpx rgba(37, 99, 235, 0.2);
}

.btn-secondary {
  background: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-success {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(22, 163, 74, 0.3);
}

.btn-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(220, 38, 38, 0.3);
}

.btn-ghost {
  background: transparent;
  color: var(--color-text-secondary);
}

.btn-ghost:active {
  background: var(--color-bg);
}

.btn:disabled {
  opacity: 0.5;
  transform: none !important;
}

/* ===== 卡片容器 ===== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl) var(--space-lg);
  margin: var(--space-md) var(--space-lg);
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.card-elevated {
  box-shadow: var(--shadow-lg);
}

.card-interactive {
  cursor: pointer;
  transition: all 0.2s ease;
}

.card-interactive:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* ===== 状态标签 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: var(--font-size-xs);
  font-weight: 600;
  line-height: 1.4;
}
.badge-draft { background: var(--color-warning-bg); color: var(--color-warning); }
.badge-submitted { background: var(--color-primary-light); color: var(--color-primary); }
.badge-reviewing { background: #f3e8ff; color: #7c3aed; }
.badge-approved { background: var(--color-success-bg); color: var(--color-success); }
.badge-rejected { background: var(--color-error-bg); color: var(--color-error); }

/* ===== 步骤标题区 ===== */
.step-section {
  padding: var(--space-lg) var(--space-lg) var(--space-sm);
}
.step-section .step-title {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  line-height: 1.3;
}
.step-section .step-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-md);
}

/* ===== 字段包装器（由 field-renderer 渲染）===== */
.field-wrapper {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  margin: 0 var(--space-lg) var(--space-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.2s ease;
}

/* 字段标题行 */
.field-header {
  margin-bottom: var(--space-md);
}
.field-header .field-header-title {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 6rpx;
}
.field-header .required {
  color: var(--color-error);
  font-size: var(--font-size-lg);
  font-weight: 700;
}
.field-header .field-title-text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}
.field-header .field-header-help {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  padding: var(--space-xs) var(--space-sm);
  background: #f8fafc;
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--color-primary);
  margin-top: 4rpx;
}

/* ===== Toast 样式 ===== */
.wx-toast {
  border-radius: var(--radius-lg) !important;
}
