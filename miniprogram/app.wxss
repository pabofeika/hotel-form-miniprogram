/** Global Styles **/
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* Common button styles */
.btn-primary {
  background: linear-gradient(135deg, #1a73e8, #1557b0);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #fff;
  color: #1a73e8;
  border: 2rpx solid #1a73e8;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
}

/* Card container */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* Step section */
.step-section {
  margin: 20rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 32rpx;
}

/* Status badges */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.badge-draft { background: #fff3e0; color: #e65100; }
.badge-submitted { background: #e3f2fd; color: #1565c0; }
.badge-reviewing { background: #f3e5f5; color: #7b1fa2; }
.badge-approved { background: #e8f5e9; color: #2e7d32; }
.badge-rejected { background: #fbe9e7; color: #c62828; }
