/**
 * ═══════════════════════════════════════════
 *   创维智慧酒店 - 设计系统 v3.0
 *   风格：Soft UI Evolution × Modern Minimal
 *   支持 Light / Dark 双主题
 * ═══════════════════════════════════════════
 */

/* ===== 亮色主题 Token (默认) ===== */
page {
  --font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 30rpx;
  --font-size-xl: 32rpx;
  --font-size-2xl: 36rpx;
  --font-size-3xl: 40rpx;

  /* 主色 */
  --color-primary: #2563eb;
  --color-primary-dark: #1d4ed8;
  --color-primary-light: #dbeafe;
  --color-primary-gradient: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);

  /* 背景 */
  --color-bg: #f4f6fa;
  --color-bg-card: #ffffff;
  --color-bg-input: #f0f2f5;
  --color-bg-hover: #eef2ff;
  --color-bg-mask: rgba(0, 0, 0, 0.4);

  /* 文字 */
  --color-text-primary: #0f172a;
  --color-text-secondary: #475569;
  --color-text-tertiary: #94a3b8;
  --color-text-placeholder: #cbd5e1;

  /* 边框 */
  --color-border: #e8ecf1;
  --color-border-focus: #2563eb;
  --color-border-active: #bfdbfe;

  /* 语义色 */
  --color-success: #16a34a;
  --color-success-bg: #f0fdf4;
  --color-warning: #d97706;
  --color-warning-bg: #fffbeb;
  --color-error: #dc2626;
  --color-error-bg: #fef2f2;
  --color-info: #2563eb;
  --color-info-bg: #eff6ff;

  /* 浮层/遮罩 */
  --color-overlay: rgba(0, 0, 0, 0.5);
  --color-glass: rgba(255, 255, 255, 0.82);

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-2xl: 40rpx;

  /* 圆角 */
  --radius-sm: 10rpx;
  --radius-md: 14rpx;
  --radius-lg: 18rpx;
  --radius-xl: 24rpx;
  --radius-2xl: 32rpx;
  --radius-full: 50%;

  /* 阴影 */
  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.08);
  --shadow-xl: 0 12px 40px rgba(0, 0, 0, 0.12);
  --shadow-glow: 0 0 20px rgba(37, 99, 235, 0.15);

  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;

  /* 平滑主题切换 */
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* ===== 暗色主题 Token ===== */
.theme-dark {
  --color-primary: #60a5fa;
  --color-primary-dark: #3b82f6;
  --color-primary-light: #1e3a5f;
  --color-primary-gradient: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);

  --color-bg: #0f1117;
  --color-bg-card: #1a1d27;
  --color-bg-input: #232734;
  --color-bg-hover: #1e2940;
  --color-bg-mask: rgba(0, 0, 0, 0.6);

  --color-text-primary: #f1f5f9;
  --color-text-secondary: #cbd5e1;
  --color-text-tertiary: #64748b;
  --color-text-placeholder: #475569;

  --color-border: #2a2e3a;
  --color-border-focus: #60a5fa;
  --color-border-active: #1e40af;

  --color-success: #4ade80;
  --color-success-bg: #0d2818;
  --color-warning: #fbbf24;
  --color-warning-bg: #281f0d;
  --color-error: #f87171;
  --color-error-bg: #2d1115;
  --color-info: #60a5fa;
  --color-info-bg: #0d1f3c;

  --color-overlay: rgba(0, 0, 0, 0.7);
  --color-glass: rgba(26, 29, 39, 0.88);

  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);
  --shadow-xl: 0 12px 40px rgba(0, 0, 0, 0.6);
  --shadow-glow: 0 0 20px rgba(96, 165, 250, 0.2);
}

/* ===== 全局过渡动效 ===== */
.fade-in {
  animation: fadeIn 0.3s ease;
}
.slide-up {
  animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}
.slide-down {
  animation: slideDown 0.3s ease;
}
.scale-in {
  animation: scaleIn 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(30rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideDown { from { opacity: 0; transform: translateY(-20rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes scaleIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
@keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }

/* ===== 按钮系统 v3 ===== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  margin: 0;
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}
.btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0);
  transition: background 0.2s ease;
}
.btn:active::after {
  background: rgba(255, 255, 255, 0.15);
}

.btn-primary {
  background: var(--color-primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-md);
}
.btn-primary:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-sm);
}

.btn-secondary {
  background: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-border);
}
.btn-secondary:active {
  background: var(--color-bg-hover);
  border-color: var(--color-primary);
}

.btn-success {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(22, 163, 74, 0.3);
  border: none;
}
.btn-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(220, 38, 38, 0.3);
  border: none;
}
.btn-ghost {
  background: transparent;
  color: var(--color-text-secondary);
  border: none;
}
.btn-ghost:active {
  background: var(--color-bg-hover);
}
.btn:disabled {
  opacity: 0.4;
  transform: none !important;
  box-shadow: none !important;
}

/* 按钮尺寸 */
.btn-lg {
  padding: 18rpx 40rpx;
  font-size: var(--font-size-base);
  border-radius: var(--radius-lg);
}
.btn-sm {
  padding: 10rpx 20rpx;
  font-size: var(--font-size-xs);
  border-radius: var(--radius-sm);
}

/* ===== 卡片容器 v3 ===== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl) var(--space-lg);
  margin: var(--space-md) var(--space-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
  transition: all 0.25s ease;
}
.card-elevated {
  box-shadow: var(--shadow-md);
}
.card-interactive {
  cursor: pointer;
}
.card-interactive:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}
.card-glass {
  background: var(--color-glass);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* ===== 字段包装器 v3 ===== */
.field-wrapper {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  margin: 0 var(--space-lg) var(--space-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
  transition: all 0.25s ease;
}
.field-wrapper:active {
  border-color: var(--color-border-focus);
  box-shadow: var(--shadow-glow);
}

/* 字段标题行 */
.field-header { margin-bottom: var(--space-md); }
.field-header .field-header-title {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 6rpx;
}
.field-header .required {
  color: var(--color-error);
  font-size: var(--font-size-lg);
  font-weight: 700;
}
.field-header .field-title-text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}
.field-header .field-header-help {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  padding: var(--space-xs) var(--space-sm);
  background: var(--color-info-bg);
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--color-primary);
  margin-top: 4rpx;
}

/* ===== 输入框 ===== */
.input-base {
  width: 100%;
  padding: var(--space-md) var(--space-lg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  background: var(--color-bg-input);
  color: var(--color-text-primary);
  transition: all 0.2s ease;
  box-sizing: border-box;
}
.input-base:focus {
  border-color: var(--color-border-focus);
  box-shadow: 0 0 0 4rpx var(--color-border-active);
  outline: none;
}
.input-base::placeholder {
  color: var(--color-text-placeholder);
}

/* ===== 状态标签 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: var(--font-size-xs);
  font-weight: 600;
  line-height: 1.5;
}
.badge-draft { background: var(--color-warning-bg); color: var(--color-warning); }
.badge-submitted { background: var(--color-info-bg); color: var(--color-primary); }
.badge-reviewing { background: #f3e8ff; color: #7c3aed; }
.badge-approved { background: var(--color-success-bg); color: var(--color-success); }
.badge-rejected { background: var(--color-error-bg); color: var(--color-error); }

/* ===== 章节标题区 ===== */
.step-section {
  padding: var(--space-lg) var(--space-lg) var(--space-sm);
}
.step-section .step-title {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  line-height: 1.3;
}
.step-section .step-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-md);
}

/* ===== Toast ===== */
.wx-toast {
  border-radius: var(--radius-lg) !important;
}

/* ===== Loading skeleton ===== */
.skeleton {
  background: linear-gradient(90deg, var(--color-bg-input) 25%, var(--color-bg-hover) 50%, var(--color-bg-input) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-md);
}
