.field-select { margin-bottom: 0; }
.picker { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; border: 2rpx solid #e8e8e8; border-radius: 16rpx; font-size: 30rpx; background: #fafafa; }
.picker.placeholder { color: #bbb; }
.arrow { font-size: 24rpx; color: #999; }
