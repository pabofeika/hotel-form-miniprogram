.field-select { margin-bottom: 0; position: relative; }
.picker { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 36rpx; border: 2rpx solid #e0e0e0; border-radius: 18rpx; font-size: 36rpx; background: #fafafa; min-height: 100rpx; box-sizing: border-box; color: #1a1a2e; }
.picker.placeholder { color: #c0c0c0; }
.arrow { font-size: 32rpx; color: #999; }

/* 弹窗遮罩 */
.popup-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 9999; display: flex; align-items: flex-end; }
.popup-content { background: #fff; border-radius: 32rpx 32rpx 0 0; width: 100%; max-height: 70vh; overflow: hidden; }
.popup-header { display: flex; justify-content: space-between; align-items: center; padding: 36rpx 36rpx 24rpx; border-bottom: 2rpx solid #f0f0f0; }
.popup-title { font-size: 36rpx; font-weight: 700; color: #1a1a2e; }
.popup-close { font-size: 40rpx; color: #999; padding: 8rpx; }
.popup-list { max-height: 60vh; padding: 16rpx; }
.popup-item { display: flex; align-items: center; padding: 32rpx 28rpx; border-bottom: 2rpx solid #f5f5f5; }
.popup-item.active { background: #f0f7ff; border-radius: 16rpx; margin: 4rpx 0; }
.popup-item-info { flex: 1; }
.popup-item-label { font-size: 36rpx; font-weight: 500; color: #1a1a2e; display: block; }
.popup-item-desc { font-size: 28rpx; color: #888; display: block; margin-top: 6rpx; }
.popup-check { width: 48rpx; height: 48rpx; border: 2rpx solid #d0d0d0; border-radius: 50%; text-align: center; line-height: 48rpx; font-size: 30rpx; color: #fff; flex-shrink: 0; }
.popup-check.checked { background: #1a73e8; border-color: #1a73e8; }
