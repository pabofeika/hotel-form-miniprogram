.field-select { margin-bottom: 8rpx; }
.field-label { font-size: 28rpx; color: #333; font-weight: 500; margin-bottom: 16rpx; }
.required { color: #d32f2f; margin-right: 4rpx; }
.picker { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; border: 2rpx solid #e0e0e0; border-radius: 12rpx; font-size: 28rpx; }
.picker.placeholder { color: #bbb; }
.arrow { font-size: 24rpx; color: #999; }
