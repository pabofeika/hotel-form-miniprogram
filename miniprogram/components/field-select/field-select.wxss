.field-select { margin-bottom: 0; position: relative; }
.picker { display: flex; align-items: center; justify-content: space-between; padding: 22rpx 28rpx; border: 1.5rpx solid var(--color-border); border-radius: var(--radius-md); font-size: var(--font-size-base); background: var(--color-bg-input); min-height: 76rpx; box-sizing: border-box; color: var(--color-text-primary); }
.picker.placeholder { color: var(--color-text-placeholder); }
.arrow { font-size: 24rpx; color: var(--color-text-tertiary); transition: transform 0.2s; }

/* 底部弹出菜单 - 毛玻璃 */
.popup-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15,23,42,0.35); z-index: 9999; display: flex; align-items: flex-end; backdrop-filter: blur(4rpx); }
.popup-content { background: var(--color-bg-card); border-radius: 28rpx 28rpx 0 0; width: 100%; max-height: 70vh; overflow: hidden; }
.popup-header { display: flex; justify-content: space-between; align-items: center; padding: var(--space-xl) var(--space-lg) var(--space-md); border-bottom: 1rpx solid var(--color-border); }
.popup-title { font-size: var(--font-size-lg); font-weight: 800; color: var(--color-text-primary); }
.popup-close { font-size: 36rpx; color: var(--color-text-tertiary); padding: 8rpx; }
.popup-list { max-height: 60vh; padding: var(--space-sm); }

.popup-item { display: flex; align-items: center; padding: var(--space-lg) var(--space-md); border-radius: var(--radius-md); transition: background 0.15s; }
.popup-item.active { background: var(--color-bg-hover); }
.popup-item:active { background: var(--color-primary-light); }
.popup-item-info { flex: 1; }
.popup-item-label { font-size: var(--font-size-base); font-weight: 500; color: var(--color-text-primary); display: block; }
.popup-item-desc { font-size: var(--font-size-xs); color: var(--color-text-tertiary); display: block; margin-top: 4rpx; }
.popup-check { width: 36rpx; height: 36rpx; border: 2rpx solid var(--color-border); border-radius: var(--radius-full); text-align: center; line-height: 36rpx; font-size: 22rpx; color: #fff; flex-shrink: 0; }
.popup-check.checked { background: var(--color-primary); border-color: var(--color-primary); }
