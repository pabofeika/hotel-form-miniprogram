.field-textarea { margin-bottom: 0; }
.textarea { width: 100%; min-height: 180rpx; padding: 24rpx 28rpx; border: 2rpx solid #e0e0e0; border-radius: 14rpx; font-size: 28rpx; color: #1a1a2e; background: #fafafa; box-sizing: border-box; }
.textarea:focus { border-color: #1a73e8; box-shadow: 0 0 0 4rpx rgba(26,115,232,0.12); background: #fff; }
