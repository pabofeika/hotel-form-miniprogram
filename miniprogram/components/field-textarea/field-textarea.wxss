.field-textarea { margin-bottom: 0; }
.textarea { width: 100%; min-height: 200rpx; padding: 28rpx 32rpx; border: 2rpx solid #e8e8e8; border-radius: 16rpx; font-size: 30rpx; color: #333; background: #fafafa; box-sizing: border-box; }
.textarea:focus { border-color: #1a73e8; box-shadow: 0 0 0 4rpx rgba(26,115,232,0.1); background: #fff; }
