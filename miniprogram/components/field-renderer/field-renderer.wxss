/** 字段包装器 - 使用全局设计 Token */
.field-wrapper { background: var(--color-bg-card); border-radius: var(--radius-xl); padding: var(--space-xl) var(--space-lg) var(--space-lg); margin-bottom: var(--space-md); box-shadow: var(--shadow-sm); border: 1rpx solid var(--color-border); }
.field-header { margin-bottom: var(--space-md); }
.field-header-title { display: flex; align-items: center; margin-bottom: 6rpx; }
.required { color: var(--color-error); font-size: var(--font-size-lg); margin-right: 4rpx; font-weight: 700; }
.field-title-text { font-size: var(--font-size-xl); font-weight: 700; color: var(--color-text-primary); line-height: 1.3; }
.field-header-help { display: block; font-size: var(--font-size-xs); color: var(--color-text-secondary); line-height: 1.5; padding: var(--space-xs) var(--space-sm); background: var(--color-info-bg); border-radius: var(--radius-sm); border-left: 4rpx solid var(--color-primary); margin-top: 4rpx; }
