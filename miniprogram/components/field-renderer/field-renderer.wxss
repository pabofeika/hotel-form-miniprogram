.field-wrapper { background: #fff; border-radius: 20rpx; padding: 28rpx 28rpx 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 2rpx solid #f0f0f0; }
.field-header { margin-bottom: 20rpx; }
.field-header-title { display: flex; align-items: center; margin-bottom: 8rpx; }
.required { color: #ff4d4f; font-size: 32rpx; margin-right: 4rpx; }
.field-title-text { font-size: 32rpx; font-weight: 700; color: #1a1a2e; line-height: 1.4; }
.field-header-help { display: block; font-size: 24rpx; color: #888; line-height: 1.5; padding: 12rpx 16rpx; background: #fafafa; border-radius: 10rpx; border-left: 6rpx solid #1a73e8; margin-top: 8rpx; }
.field-body { }
