.template-options {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.template-option {
  display: flex;
  align-items: center;
  padding: var(--space-md);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  cursor: pointer;
  position: relative;
  overflow: hidden;
}
.template-option.active {
  border-color: var(--color-primary);
  background: var(--color-bg-hover);
  box-shadow: 0 0 0 4rpx var(--color-border-active), var(--shadow-md);
}
.template-option.active::after {
  content: '✓';
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.template-thumb {
  width: 160rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--color-bg-input);
  object-fit: cover;
}

.template-info {
  flex: 1;
  margin-left: var(--space-md);
  min-width: 0;
}
.template-label {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}
.template-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.preview-btn {
  width: 140rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 自定义预览弹窗 */
.preview-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99999;
  background: rgba(0, 0, 0, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
}
.preview-image {
  width: 1125rpx;
  transform: rotate(90deg);
}

/* 关闭按钮 */
.preview-close {
  position: fixed;
  top: 60rpx;
  right: 30rpx;
  z-index: 100000;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 300;
}
