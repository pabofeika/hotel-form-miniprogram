.template-options {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.template-option {
  display: flex;
  align-items: center;
  padding: var(--space-md);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  transition: all 0.2s;
  cursor: pointer;
}
.template-option.active {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3rpx var(--color-border-active);
}

.template-thumb {
  width: 140rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--color-bg-input);
  object-fit: cover;
}

.template-info {
  flex: 1;
  margin-left: var(--space-md);
  min-width: 0;
}
.template-label {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}
.template-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.preview-btn {
  width: 140rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 自定义预览弹窗 */
.preview-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99999;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
}
.preview-image {
  width: 100vw;
  height: 82vh;
}
