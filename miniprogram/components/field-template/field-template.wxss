.field-template { margin-bottom: 0; }
.field-label { font-size: 28rpx; font-weight: 600; color: #1a1a2e; margin-bottom: 20rpx; }
.required { color: #ff4d4f; margin-right: 6rpx; }
.template-list { display: flex; flex-direction: column; gap: 20rpx; }
.template-card { display: flex; align-items: center; gap: 24rpx; padding: 24rpx; border: 2rpx solid #e8e8e8; border-radius: 16rpx; background: #fff; }
.template-card.active { border-color: #1a73e8; background: #f0f7ff; }
.template-image { width: 160rpx; height: 120rpx; border-radius: 12rpx; flex-shrink: 0; background: #f5f5f5; }
.template-info { flex: 1; min-width: 0; }
.template-title { font-size: 28rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 6rpx; }
.template-desc { font-size: 22rpx; color: #888; display: block; }
.check-circle { width: 44rpx; height: 44rpx; border: 2rpx solid #d0d0d0; border-radius: 50%; text-align: center; line-height: 44rpx; font-size: 26rpx; color: #fff; flex-shrink: 0; }
.check-circle.checked { background: #1a73e8; border-color: #1a73e8; }
