<view class="template-options">
  <view
    wx:for="{{options}}"
    wx:key="value"
    class="template-option {{currentValue === item.value ? 'active' : ''}}"
    data-value="{{item.value}}"
    bindtap="onSelect"
  >
    <image
      class="template-thumb"
      src="{{item.thumb || item.image}}"
      mode="aspectFill"
      data-url="{{item.thumb || item.image}}"
      bindload="onImageLoad"
      binderror="onImageError"
    />

    <view class="template-info">
      <view class="template-label">{{item.label}}</view>
      <view class="template-desc">{{item.desc}}</view>
    </view>

    <button
      class="preview-btn"
      data-url="{{item.image || item.thumb}}"
      catchtap="onPreviewImage"
    >
      查看大图
    </button>
  </view>
</view>

<view
  wx:if="{{previewVisible}}"
  class="preview-mask"
  catchtap="closePreview"
  catchtouchstart="onTouchStart"
  catchtouchend="onTouchEnd"
>
  <view class="preview-close" catchtap="closePreview">
    <text>✕</text>
  </view>
  <image
    class="preview-image"
    src="{{previewImageUrl}}"
    mode="aspectFit"
    catchtap="closePreview"
    bindload="onPreviewImageLoad"
    binderror="onPreviewImageError"
  />

  <!-- 上/下一张 -->
  <view wx:if="{{!previewPrevDisabled}}" class="preview-arrow prev" catchtap="previewPrev">
    <text>▲ 上一个</text>
  </view>
  <view wx:if="{{!previewNextDisabled}}" class="preview-arrow next" catchtap="previewNext">
    <text>▼ 下一个</text>
  </view>

  <!-- 页码 -->
  <view class="preview-pagination">
    <text>{{previewIndex + 1}} / {{options.length}}</text>
  </view>
</view>
