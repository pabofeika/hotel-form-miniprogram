<view class="field-template">
  <radio-group class="template-group" bindchange="onChange">
    <label wx:for="{{options}}" wx:key="value" class="template-item {{item.value === currentValue ? 'active' : ''}}">
      <radio value="{{item.value}}" checked="{{item.value === currentValue}}" class="template-radio" />
      <image class="template-image" src="{{item.image || '/images/template-default.png'}}" mode="aspectFill" />
      <view class="template-content">
        <text class="template-title">{{item.label}}</text>
        <text wx:if="{{item.desc}}" class="template-desc">{{item.desc}}</text>
      </view>
    </label>
  </radio-group>
</view>
