<view class="template-options">
  <view
    wx:for="{{options}}"
    wx:key="value"
    class="template-option {{currentValue === item.value ? 'active' : ''}}"
    data-value="{{item.value}}"
    bindtap="onSelect"
  >
    <image
      class="template-thumb"
      src="{{item.thumb || item.image}}"
      mode="aspectFill"
      data-url="{{item.thumb || item.image}}"
      bindload="onImageLoad"
      binderror="onImageError"
    />

    <view class="template-info">
      <view class="template-label">{{item.label}}</view>
      <view class="template-desc">{{item.desc}}</view>
    </view>

    <button
      class="preview-btn"
      data-url="{{item.image || item.thumb}}"
      catchtap="onPreviewImage"
    >
      查看大图
    </button>
  </view>
</view>

<view
  wx:if="{{previewVisible}}"
  class="preview-mask"
  catchtap="closePreview"
>
  <!-- 关闭按钮 -->
  <view class="preview-close" catchtap="closePreview">
    <text>✕</text>
  </view>

  <view class="preview-content" catchtap="stopPreviewTap">
    <image
      class="preview-image"
      src="{{previewImageUrl}}"
      mode="aspectFit"
      bindtouchstart="onTouchStart"
      bindtouchend="onTouchEnd"
      bindload="onPreviewImageLoad"
      binderror="onPreviewImageError"
    />

    <button
      class="preview-nav preview-prev {{previewPrevDisabled ? 'disabled' : ''}}"
      disabled="{{previewPrevDisabled}}"
      catchtap="previewPrev"
    ></button>

    <button
      class="preview-nav preview-next {{previewNextDisabled ? 'disabled' : ''}}"
      disabled="{{previewNextDisabled}}"
      catchtap="previewNext"
    ></button>

    <!-- 页码 -->
    <view class="preview-pagination">{{previewIndex + 1}} / {{options.length}}</view>
  </view>
</view>
