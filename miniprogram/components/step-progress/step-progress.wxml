<!-- 步骤进度条组件 -->
<view class="step-progress">
  <view class="step-dots">
    <view
      wx:for="{{steps}}"
      wx:key="id"
      class="step-dot {{item.step_number < currentStep ? 'completed' : item.step_number === currentStep ? 'active' : ''}}"
    >
      <view class="dot"></view>
      <text class="step-num">{{item.step_number}}</text>
    </view>
  </view>
  <view class="step-names">
    <view
      wx:for="{{steps}}"
      wx:key="id"
      class="step-name {{item.step_number === currentStep ? 'active' : ''}}"
    >{{item.title}}</view>
  </view>
</view>
