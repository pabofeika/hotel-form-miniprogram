.field-multi-select { margin-bottom: 0; }
.multi-group { display: flex; flex-wrap: wrap; gap: var(--space-sm); }
.multi-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 22rpx; border: 1.5rpx solid var(--color-border); border-radius: var(--radius-md); background: var(--color-bg-card); transition: all 0.2s; }
.multi-item.checked { border-color: var(--color-border-focus); background: var(--color-bg-hover); }
.multi-item:active { transform: scale(0.97); }
.multi-checkbox { flex-shrink: 0; }
.multi-label { font-size: var(--font-size-sm); color: var(--color-text-primary); }
