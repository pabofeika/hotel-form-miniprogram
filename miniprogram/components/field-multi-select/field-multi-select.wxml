<view class="field-multi-select">
  <view class="field-label"><text wx:if="{{required}}" class="required">*</text><text>{{label}}</text></view>
  <view class="options">
    <view wx:for="{{options}}" wx:key="value" class="option {{isSelected(item.value) ? 'selected' : ''}}" bindtap="toggleOption" data-value="{{item.value}}">
      <text>{{item.label}}</text>
      <text wx:if="{{isSelected(item.value)}}" class="checkmark">✓</text>
    </view>
  </view>
</view>
