.field-file { margin-bottom: 8rpx; }
.field-label { font-size: 28rpx; color: #333; font-weight: 500; margin-bottom: 16rpx; }
.required { color: #d32f2f; margin-right: 4rpx; }
.upload-area { padding: 32rpx; border: 2rpx dashed #ccc; border-radius: 12rpx; text-align: center; background: #fafafa; }
.upload-placeholder { font-size: 26rpx; color: #bbb; }
.uploaded-file { display: flex; align-items: center; justify-content: space-between; }
.file-name { font-size: 26rpx; color: #333; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.file-status { font-size: 24rpx; color: #43a047; background: #e8f5e9; padding: 4rpx 12rpx; border-radius: 8rpx; }
