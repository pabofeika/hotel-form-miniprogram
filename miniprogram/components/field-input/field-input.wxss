.field-input { margin-bottom: 0; }
.input { width: 100%; padding: 32rpx 36rpx; border: 2rpx solid #e0e0e0; border-radius: 18rpx; font-size: 32rpx; color: #1a1a2e; background: #fafafa; box-sizing: border-box; min-height: 96rpx; }
.input:focus { border-color: #1a73e8; box-shadow: 0 0 0 4rpx rgba(26,115,232,0.12); background: #fff; }
