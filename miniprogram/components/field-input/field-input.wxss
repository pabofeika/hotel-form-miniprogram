/** 输入框 - 柔和聚焦，呼吸感 */
.field-input { margin-bottom: 0; }
.input { width: 100%; padding: 22rpx 28rpx; border: 1.5rpx solid var(--color-border); border-radius: var(--radius-md); font-size: var(--font-size-base); color: var(--color-text-primary); background: var(--color-bg-input); box-sizing: border-box; min-height: 76rpx; transition: all 0.2s ease; }
.input:focus { border-color: var(--color-border-focus); box-shadow: 0 0 0 4rpx rgba(37,99,235,0.1); background: var(--color-bg-card); }
