/** 预览页 - 收敛确认感 */
.page { padding: var(--space-xl); padding-bottom: 220rpx; background: var(--color-bg); min-height: 100vh; }
.preview-header { margin-bottom: var(--space-2xl); }
.preview-title { font-size: var(--font-size-2xl); font-weight: 800; display: block; margin-bottom: 8rpx; color: var(--color-text-primary); }
.preview-desc { font-size: var(--font-size-sm); color: var(--color-text-tertiary); }

.preview-step { background: var(--color-bg-card); border-radius: var(--radius-xl); padding: var(--space-xl); margin-bottom: var(--space-lg); box-shadow: var(--shadow-sm); border: 1rpx solid rgba(0,0,0,0.03); }
.preview-step-header { display: flex; align-items: center; margin-bottom: var(--space-lg); }
.preview-step-num { background: var(--color-primary-gradient); color: #fff; padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 20rpx; font-weight: 700; margin-right: var(--space-sm); }
.preview-step-title { font-size: var(--font-size-lg); font-weight: 700; color: var(--color-text-primary); }
.preview-field { padding: var(--space-md) 0; border-bottom: 1rpx solid var(--color-border); }
.preview-field:last-child { border-bottom: none; }
.field-label { font-size: var(--font-size-xs); color: var(--color-text-tertiary); display: block; margin-bottom: 6rpx; }
.field-value { font-size: var(--font-size-base); color: var(--color-text-primary); display: block; font-weight: 500; }

/* 底部操作区 */
.action-area { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: var(--space-md); padding: var(--space-md) var(--space-lg) 48rpx; background: rgba(255,255,255,0.92); backdrop-filter: blur(20rpx); box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06); border-radius: 24rpx 24rpx 0 0; }
