/** 预览页 - 收敛确认感 */
.page { padding: var(--space-xl); padding-bottom: 220rpx; background: var(--color-bg); min-height: 100vh; }
.loading-container { display: flex; justify-content: center; align-items: center; height: 500rpx; font-size: var(--font-size-base); color: var(--color-text-tertiary); }

.preview-header { margin-bottom: var(--space-2xl); }
.preview-title { font-size: var(--font-size-2xl); font-weight: 800; display: block; margin-bottom: 8rpx; color: var(--color-text-primary); }
.preview-desc { font-size: var(--font-size-sm); color: var(--color-text-tertiary); }

/* 预览条目列表 */
.preview-list { margin-bottom: var(--space-lg); }
.preview-item { display: flex; flex-direction: column; background: var(--color-bg-card); padding: var(--space-lg) var(--space-lg); border-radius: var(--radius-lg); margin-bottom: var(--space-sm); box-shadow: var(--shadow-sm); border: 1rpx solid var(--color-border); }
.preview-label { font-size: var(--font-size-xs); color: var(--color-text-tertiary); display: block; margin-bottom: 6rpx; font-weight: 500; }
.preview-value { font-size: var(--font-size-base); color: var(--color-text-primary); display: block; font-weight: 500; line-height: 1.6; }

/* 空状态 */
.empty { text-align: center; padding: 200rpx 0; }
.empty-text { font-size: var(--font-size-base); color: var(--color-text-tertiary); }

/* 底部操作区 */
.action-area { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: var(--space-md); justify-content: center; padding: var(--space-md) var(--space-lg) 48rpx; background: rgba(255,255,255,0.92); backdrop-filter: blur(20rpx); box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06); border-radius: 24rpx 24rpx 0 0; }

/* 主题切换按钮 */
.theme-toggle { position: fixed; top: 24rpx; right: 24rpx; z-index: 999; width: 60rpx; height: 60rpx; border-radius: var(--radius-full); background: rgba(255,255,255,0.82); backdrop-filter: blur(20rpx); display: flex; align-items: center; justify-content: center; font-size: 30rpx; box-shadow: var(--shadow-md); border: 1rpx solid var(--color-border); }
