/** 预览页 */
.page { padding: 32rpx; padding-bottom: 200rpx; background: #f5f7fa; min-height: 100vh; }
.preview-header { margin-bottom: 40rpx; }
.preview-title { font-size: 40rpx; font-weight: 700; display: block; margin-bottom: 12rpx; color: #1a1a2e; }
.preview-desc { font-size: 26rpx; color: #888; }
.preview-step { background: #fff; border-radius: 20rpx; padding: 36rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.preview-step-header { display: flex; align-items: center; margin-bottom: 28rpx; }
.preview-step-num { background: linear-gradient(135deg, #1a73e8, #0d47a1); color: #fff; padding: 6rpx 20rpx; border-radius: 10rpx; font-size: 22rpx; font-weight: 600; margin-right: 16rpx; }
.preview-step-title { font-size: 32rpx; font-weight: 600; color: #1a1a2e; }
.preview-field { padding: 20rpx 0; border-bottom: 2rpx solid #f5f5f5; }
.preview-field:last-child { border-bottom: none; }
.field-label { font-size: 26rpx; color: #888; display: block; margin-bottom: 8rpx; }
.field-value { font-size: 30rpx; color: #333; display: block; font-weight: 500; }

/* 操作区悬浮 */
.action-area { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 20rpx; padding: 24rpx 32rpx 44rpx; background: #fff; box-shadow: 0 -6rpx 24rpx rgba(0,0,0,0.08); border-radius: 24rpx 24rpx 0 0; }
.btn-back, .btn-submit { flex: 1; padding: 28rpx; border-radius: 16rpx; font-size: 30rpx; font-weight: 600; text-align: center; }
.btn-back { background: #f5f5f5; color: #666; }
.btn-submit { background: linear-gradient(135deg, #52c41a, #389e0d); color: #fff; box-shadow: 0 4rpx 16rpx rgba(82,196,26,0.3); }
