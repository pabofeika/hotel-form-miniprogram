/** 预览页面样式 */
.page { padding: 32rpx; padding-bottom: 180rpx; }
.preview-header { margin-bottom: 40rpx; }
.preview-title { font-size: 40rpx; font-weight: 700; display: block; margin-bottom: 12rpx; }
.preview-desc { font-size: 26rpx; color: #888; }
.preview-step { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.preview-step-header { display: flex; align-items: center; margin-bottom: 24rpx; }
.preview-step-num { background: #1a73e8; color: #fff; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; margin-right: 16rpx; }
.preview-step-title { font-size: 32rpx; font-weight: 600; }
.preview-field { padding: 16rpx 0; border-bottom: 2rpx solid #f5f5f5; }
.preview-field:last-child { border-bottom: none; }
.field-label { font-size: 26rpx; color: #888; display: block; margin-bottom: 8rpx; }
.field-value { font-size: 30rpx; color: #333; display: block; }
.action-area { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 20rpx; padding: 20rpx 32rpx 40rpx; background: #fff; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08); }
.btn-back, .btn-submit { flex: 1; padding: 24rpx; border-radius: 12rpx; font-size: 30rpx; text-align: center; }
.btn-back { background: #f5f5f5; color: #666; }
.btn-submit { background: linear-gradient(135deg, #43a047, #2e7d32); color: #fff; }
