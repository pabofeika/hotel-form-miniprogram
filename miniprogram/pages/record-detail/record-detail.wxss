/** 记录详情样式 */
.page { padding: 32rpx; }
.loading { text-align: center; padding: 200rpx 0; font-size: 28rpx; color: #999; }
.record-header { background: linear-gradient(135deg, #1a73e8, #0d47a1); color: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; display: flex; justify-content: space-between; align-items: center; }
.record-sn { font-size: 32rpx; font-weight: 600; }
.section { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 24rpx; }
.step-values { margin-bottom: 24rpx; }
.step-label { font-size: 26rpx; color: #1a73e8; font-weight: 500; display: block; margin-bottom: 16rpx; padding: 8rpx 0; border-bottom: 2rpx solid #e3f2fd; }
.value-row { display: flex; padding: 12rpx 0; }
.value-label { width: 200rpx; font-size: 26rpx; color: #888; }
.value-text { flex: 1; font-size: 28rpx; color: #333; }
.feedback-item { padding: 20rpx 0; border-bottom: 2rpx solid #f5f5f5; }
.feedback-item:last-child { border-bottom: none; }
.feedback-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.feedback-admin { font-weight: 600; color: #333; font-size: 26rpx; }
.feedback-date { font-size: 22rpx; color: #bbb; }
.feedback-content { font-size: 28rpx; color: #555; line-height: 1.6; }
.no-feedback { text-align: center; color: #bbb; padding: 40rpx 0; }
