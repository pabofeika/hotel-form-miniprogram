/** 记录详情 */
.page { padding: 32rpx; background: #f5f7fa; min-height: 100vh; }
.loading { text-align: center; padding: 300rpx 0; font-size: 28rpx; color: #999; }
.record-header { background: linear-gradient(135deg, #1a73e8, #0d47a1); color: #fff; border-radius: 20rpx; padding: 36rpx; margin-bottom: 24rpx; display: flex; justify-content: space-between; align-items: center; }
.record-sn { font-size: 32rpx; font-weight: 600; }
.section { background: #fff; border-radius: 20rpx; padding: 36rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.section-title { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 24rpx; color: #1a1a2e; }
.step-values { margin-bottom: 28rpx; }
.step-label { font-size: 26rpx; color: #1a73e8; font-weight: 600; display: block; margin-bottom: 16rpx; padding: 8rpx 0; border-bottom: 2rpx solid #e8f0fe; }
.value-row { display: flex; padding: 16rpx 0; }
.value-label { width: 200rpx; font-size: 26rpx; color: #888; }
.value-text { flex: 1; font-size: 28rpx; color: #333; font-weight: 500; }
.feedback-item { padding: 24rpx 0; border-bottom: 2rpx solid #f5f5f5; }
.feedback-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.feedback-admin { font-weight: 600; color: #333; font-size: 26rpx; }
.feedback-date { font-size: 22rpx; color: #bbb; }
.feedback-content { font-size: 28rpx; color: #555; line-height: 1.6; }
.no-feedback { text-align: center; color: #bbb; padding: 60rpx 0; font-size: 26rpx; }
