/** 订单详情 - 直接展示预览条目 */
.page { padding: var(--space-xl); background: var(--color-bg); min-height: 100vh; }
.loading { text-align: center; padding: 300rpx 0; font-size: var(--font-size-base); color: var(--color-text-tertiary); }

/* 顶部状态头 */
.order-header { background: var(--color-primary-gradient); color: #fff; border-radius: var(--radius-xl); padding: var(--space-xl); margin-bottom: var(--space-lg); position: relative; overflow: hidden; }
.order-header::after { content: ''; position: absolute; top: -80rpx; right: -40rpx; width: 200rpx; height: 200rpx; background: rgba(255,255,255,0.06); border-radius: 50%; }
.order-sn { font-size: var(--font-size-lg); font-weight: 700; position: relative; z-index: 1; }

/* 区域卡片 */
.section { background: var(--color-bg-card); border-radius: var(--radius-xl); padding: var(--space-xl); margin-bottom: var(--space-lg); box-shadow: var(--shadow-sm); border: 1rpx solid rgba(0,0,0,0.03); }
.section-title { font-size: var(--font-size-lg); font-weight: 700; display: block; margin-bottom: var(--space-lg); color: var(--color-text-primary); }

/* 预览条目列表 */
.detail-list { }
.detail-item { display: flex; flex-direction: column; padding: var(--space-sm) 0; border-bottom: 1rpx solid var(--color-border); }
.detail-item:last-child { border-bottom: none; }
.detail-label { font-size: var(--font-size-xs); color: var(--color-text-tertiary); display: block; margin-bottom: 4rpx; }
.detail-value { font-size: var(--font-size-base); color: var(--color-text-primary); font-weight: 500; display: block; line-height: 1.6; }

/* 空状态 */
.empty { text-align: center; padding: 200rpx 0; font-size: var(--font-size-base); color: var(--color-text-tertiary); }

/* 主题切换按钮 */
.theme-toggle { position: fixed; top: 24rpx; right: 24rpx; z-index: 999; width: 60rpx; height: 60rpx; border-radius: var(--radius-full); background: var(--color-glass); backdrop-filter: blur(20rpx); -webkit-backdrop-filter: blur(20rpx); display: flex; align-items: center; justify-content: center; font-size: 30rpx; box-shadow: var(--shadow-md); border: 1rpx solid var(--color-border); }
