<!-- 订单详情页 - 直接显示已保存的预览条目 -->
<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:else class="content">
    <!-- 订单头部 -->
    <view class="order-header" wx:if="{{order}}">
      <text class="order-sn">{{order.id}}</text>
    </view>

    <!-- 预览条目 -->
    <view class="section" wx:if="{{previewItems.length > 0}}">
      <text class="section-title">填写内容</text>
      <view class="detail-list">
        <view class="detail-item" wx:for="{{previewItems}}" wx:key="key">
          <text class="detail-label">{{item.label}}</text>
          <text class="detail-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:else>
      <text>暂无订单信息</text>
    </view>
  </view>
</view>
