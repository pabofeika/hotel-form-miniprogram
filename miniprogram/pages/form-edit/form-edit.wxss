/** 表单编辑页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
  background: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}

.form-content {
  padding-bottom: 40rpx;
}

.fields-area {
  padding: 0 20rpx;
}

.field-error {
  margin: -12rpx 32rpx 16rpx;
  padding: 8rpx 16rpx;
  background: #fff0f0;
  border-radius: 8rpx;
}

.field-error text {
  font-size: 24rpx;
  color: #d32f2f;
}

/* Bottom action bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.action-right {
  display: flex;
  gap: 16rpx;
  margin-left: auto;
}

.btn {
  padding: 20rpx 36rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  text-align: center;
  line-height: 1.4;
}

.btn-prev {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: #fff;
  color: #1a73e8;
  border: 2rpx solid #1a73e8;
}

.btn-next {
  background: linear-gradient(135deg, #1a73e8, #1557b0);
  color: #fff;
}

.btn-submit {
  background: linear-gradient(135deg, #43a047, #2e7d32);
  color: #fff;
}
