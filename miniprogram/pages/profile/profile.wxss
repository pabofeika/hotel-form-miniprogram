/** 个人中心 */
.page { min-height: 100vh; background: #f5f7fa; }
.user-card { background: linear-gradient(135deg, #1a73e8, #0d47a1); padding: 80rpx 32rpx 60rpx; text-align: center; color: #fff; border-radius: 0 0 40rpx 40rpx; }
.avatar { font-size: 120rpx; margin-bottom: 16rpx; display: block; }
.user-name { font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.user-desc { font-size: 24rpx; opacity: 0.8; display: block; }
.menu-list { margin: 32rpx 24rpx; background: #fff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 36rpx; border-bottom: 2rpx solid #f5f5f5; font-size: 28rpx; }
.menu-item:last-child { border-bottom: none; }
.menu-arrow { font-size: 36rpx; color: #ddd; }
.version-info { text-align: center; padding: 60rpx; font-size: 24rpx; color: #bbb; }
