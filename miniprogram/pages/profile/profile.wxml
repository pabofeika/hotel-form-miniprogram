<view class="page theme-{{theme}}">
  <!-- 主题切换按钮 -->
  <view class="theme-toggle" bindtap="toggleTheme">
    <text wx:if="{{theme === 'light'}}">🌙</text>
    <text wx:else>☀️</text>
  </view>

  <view class="user-card" style="padding: 80rpx 36rpx 60rpx; background: var(--color-primary-gradient); text-align: center; color: #fff; border-radius: 0 0 40rpx 40rpx; position: relative; overflow: hidden;">
    <view class="avatar" style="font-size: 80rpx; margin-bottom: 16rpx;">👤</view>
    <text class="user-name" style="display: block; font-size: 36rpx; font-weight: 800; margin-bottom: 6rpx;">{{userName}}</text>
    <text class="user-desc" style="display: block; font-size: 22rpx; opacity: 0.8;">{{userDesc}}</text>
  </view>

  <view class="menu-list" style="margin: var(--space-lg);">
    <view class="menu-item card" bindtap="goToRecords" style="display: flex; justify-content: space-between; align-items: center; padding: var(--space-lg); margin: 0 0 var(--space-md); border-radius: var(--radius-xl); cursor: pointer;">
      <text>📋 我的提交</text>
      <text class="menu-arrow" style="font-size: 40rpx; color: var(--color-border);">›</text>
    </view>
    <view class="menu-item card" bindtap="clearCache" style="display: flex; justify-content: space-between; align-items: center; padding: var(--space-lg); margin: 0 0 var(--space-md); border-radius: var(--radius-xl); cursor: pointer;">
      <text>🗑️ 清除缓存</text>
      <text class="menu-arrow" style="font-size: 40rpx; color: var(--color-border);">›</text>
    </view>
  </view>

  <view class="version-info" style="text-align: center; padding: 40rpx 0; font-size: var(--font-size-xs); color: var(--color-text-tertiary);">
    <text>版本 1.0.0</text>
  </view>
</view>
