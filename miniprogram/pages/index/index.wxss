/** 首页 - 现代化卡片列表 */
.page { min-height: 100vh; padding-bottom: 40rpx; }
.loading { display: flex; justify-content: center; align-items: center; height: 500rpx; font-size: var(--font-size-base); color: var(--color-text-tertiary); }

/* 渐变顶栏 */
.page-header { padding: 80rpx 36rpx 50rpx; background: var(--color-primary-gradient); color: #fff; border-radius: 0 0 36rpx 36rpx; position: relative; overflow: hidden; }
.page-header::after { content: ''; position: absolute; top: -100rpx; right: -60rpx; width: 300rpx; height: 300rpx; background: rgba(255,255,255,0.06); border-radius: 50%; }
.page-title { display: block; font-size: 44rpx; font-weight: 800; margin-bottom: 10rpx; letter-spacing: 1rpx; position: relative; z-index: 1; }
.page-subtitle { display: block; font-size: 24rpx; opacity: 0.8; position: relative; z-index: 1; }

/* 草稿恢复条 - 毛玻璃效果 */
.draft-banner { display: flex; align-items: center; margin: var(--space-lg) var(--space-lg) 0; padding: var(--space-md) var(--space-lg); border-radius: var(--radius-lg); background: rgba(255, 193, 7, 0.1); border: 1rpx solid rgba(255, 193, 7, 0.3); backdrop-filter: blur(10rpx); }
.draft-icon { font-size: 36rpx; margin-right: 16rpx; }
.draft-text { flex: 1; font-size: var(--font-size-sm); color: #92400e; }
.draft-arrow { font-size: 36rpx; color: #f59e0b; font-weight: 700; }

/* 表单卡片 - 沉浸式卡片堆叠 */
.form-card { background: var(--color-bg-card); margin: var(--space-md) var(--space-lg) 0; padding: var(--space-xl) var(--space-lg); border-radius: var(--radius-xl); box-shadow: var(--shadow-md); border: 1rpx solid rgba(0,0,0,0.03); transition: all 0.2s ease; }
.form-card:active { transform: scale(0.98); box-shadow: var(--shadow-sm); }
.card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.card-title { font-size: var(--font-size-xl); font-weight: 700; flex: 1; color: var(--color-text-primary); }
.card-version { font-size: 20rpx; color: var(--color-primary); background: var(--color-primary-light); padding: 4rpx 14rpx; border-radius: 20rpx; font-weight: 600; }
.card-desc { font-size: var(--font-size-sm); color: var(--color-text-secondary); line-height: 1.6; margin-bottom: var(--space-md); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.card-footer { display: flex; justify-content: space-between; align-items: center; }
.card-date { font-size: 20rpx; color: var(--color-text-tertiary); }
.card-action { font-size: var(--font-size-base); color: var(--color-primary); font-weight: 600; }

/* 空状态 */
.empty { display: flex; flex-direction: column; align-items: center; padding: 200rpx 0; }
.empty-icon { font-size: 100rpx; margin-bottom: var(--space-lg); opacity: 0.5; }
.empty-text { font-size: var(--font-size-base); color: var(--color-text-tertiary); }
