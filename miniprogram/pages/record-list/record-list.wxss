/** 记录列表 */
.page { min-height: 100vh; background: #f5f5f5; }
.tabs { display: flex; background: #fff; padding: 20rpx 16rpx; margin-bottom: 8rpx; border-radius: 0 0 20rpx 20rpx; }
.tab { flex: 1; text-align: center; padding: 18rpx; font-size: 28rpx; color: #666; border-radius: 12rpx; }
.tab-active { background: #e8f0fe; color: #1a73e8; font-weight: 600; }
.record-card { background: #fff; margin: 16rpx 20rpx; padding: 36rpx; border-radius: 20rpx; position: relative; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.record-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.record-sn { font-size: 28rpx; font-weight: 600; color: #1a1a2e; }
.record-date { font-size: 24rpx; color: #bbb; }
.record-arrow { position: absolute; right: 36rpx; top: 50%; transform: translateY(-50%); font-size: 40rpx; color: #ddd; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 200rpx 0; }
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #bbb; }
