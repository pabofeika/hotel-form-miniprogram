/** 记录列表 - 清爽筛选+卡片 */
.page { min-height: 100vh; background: var(--color-bg); }

/* 筛选标签栏 */
.tabs { display: flex; gap: var(--space-xs); background: var(--color-bg-card); padding: var(--space-md); margin-bottom: 4rpx; border-radius: 0 0 var(--radius-xl) var(--radius-xl); box-shadow: var(--shadow-sm); }
.tab { flex: 1; text-align: center; padding: 14rpx; font-size: var(--font-size-sm); color: var(--color-text-secondary); border-radius: var(--radius-md); transition: all 0.2s; }
.tab-active { background: var(--color-primary-gradient); color: #fff; font-weight: 600; box-shadow: 0 2rpx 8rpx rgba(37,99,235,0.25); }

/* 记录卡片 */
.record-card { background: var(--color-bg-card); margin: var(--space-md) var(--space-lg); padding: var(--space-xl); border-radius: var(--radius-xl); position: relative; box-shadow: var(--shadow-sm); border: 1rpx solid var(--color-border); transition: all 0.2s; }
.record-card:active { transform: scale(0.98); }
.record-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-sm); }
.record-sn { font-size: var(--font-size-base); font-weight: 700; color: var(--color-text-primary); font-family: 'Courier New', monospace; }
.record-date { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
.record-arrow { position: absolute; right: var(--space-xl); top: 50%; transform: translateY(-50%); font-size: 40rpx; color: var(--color-border); }

/* 空状态 */
.empty { display: flex; flex-direction: column; align-items: center; padding: 250rpx 0; }
.empty-icon { font-size: 100rpx; margin-bottom: var(--space-lg); opacity: 0.4; }
.empty-text { font-size: var(--font-size-base); color: var(--color-text-tertiary); }

/* 主题切换按钮 */
.theme-toggle { position: fixed; top: 24rpx; right: 24rpx; z-index: 999; width: 60rpx; height: 60rpx; border-radius: var(--radius-full); background: var(--color-glass); backdrop-filter: blur(20rpx); -webkit-backdrop-filter: blur(20rpx); display: flex; align-items: center; justify-content: center; font-size: 30rpx; box-shadow: var(--shadow-md); border: 1rpx solid var(--color-border); }
